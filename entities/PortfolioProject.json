{
  "name": "PortfolioProject",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Project title"
    },
    "description": {
      "type": "string",
      "description": "Project description"
    },
    "category": {
      "type": "string",
      "enum": [
        "Robotics",
        "PCB",
        "3D Print",
        "Engineering",
        "Other"
      ],
      "default": "Robotics"
    },
    "image_url": {
      "type": "string",
      "description": "Main project image"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Gallery images"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Technology tags"
    },
    "technical_details": {
      "type": "string",
      "description": "Technical specifications and details"
    },
    "results": {
      "type": "string",
      "description": "Results, awards, outcomes"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title"
  ]
}